<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXPasswordField?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<BorderPane
        xmlns:fx="http://javafx.com/fxml/1"
        xmlns="http://javafx.com/javafx/21"
        fx:controller="dev.danipraivet.controlador.ControladorLogin"
        style="-fx-background-color: #E8EAF6;">

    <center>
        <VBox alignment="CENTER" spacing="20" maxWidth="400" maxHeight="550"
              style="-fx-background-color: white;
                     -fx-background-radius: 18;
                     -fx-effect: dropshadow(gaussian, rgba(63,81,181,0.22), 28, 0, 0, 8);
                     -fx-padding: 44 40 36 40;">

            <ImageView fitWidth="190" fitHeight="72" preserveRatio="true">
                <image>
                    <Image url="@fuente/../logo/logo_negro.png"/>
                </image>
            </ImageView>

            <VBox alignment="CENTER" spacing="4">
                <Label text="Control de Asistencia"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #000057;"/>
                <Label text="Introduce tus credenciales para acceder"
                       style="-fx-font-size: 12px; -fx-text-fill: #9e9e9e;"/>
            </VBox>

            <Separator style="-fx-opacity: 0.4;"/>

            <MFXTextField
                    fx:id="txtUsername"
                    floatingText="Usuario"
                    maxWidth="Infinity"
                    prefHeight="52"
                    style="-fx-border-color: #000057; "/>

            <MFXPasswordField
                    fx:id="txtContrasena"
                    floatingText="Contraseña"
                    maxWidth="Infinity"
                    prefHeight="52"
                    style="-fx-border-color: #000057;"/>

            <Label fx:id="lblError"
                   text="" visible="false" wrapText="true"
                   maxWidth="Infinity"
                   style="-fx-text-fill: #c62828; -fx-font-size: 12px;
                          -fx-background-color: #ffebee; -fx-background-radius: 8;
                          -fx-padding: 10 14;"/>

            <MFXButton fx:id="btnLogin"
                       text="Entrar"
                       maxWidth="Infinity"
                       prefHeight="52"
                       onAction="#onLogin"
                       style="-fx-background-color: #000057;
                              -fx-text-fill: white;
                              -fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-background-radius: 10;
                              -fx-cursor: hand;"/>

            <Label text="v1.0.0 · Clockio"
                   style="-fx-text-fill: #bdbdbd; -fx-font-size: 11px;"/>
        </VBox>
    </center>
</BorderPane>
