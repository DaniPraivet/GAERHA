<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane
        xmlns:fx="http://javafx.com/fxml/1"
        xmlns="http://javafx.com/javafx/21"
        fx:controller="dev.danipraivet.controlador.ControladorRRHH"
        style="-fx-background-color: #E8F5E9;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1b5e20;
                     -fx-padding: 14 28;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 4);">
            <Label text="Clockio · Recursos Humanos"
                   style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblBienvenidaRRHH"
                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
            <MFXButton text="Cerrar sesión" onAction="#onLogout"
                       style="-fx-background-color: rgba(255,255,255,0.18);
                              -fx-text-fill: white; -fx-background-radius: 8;
                              -fx-cursor: hand; -fx-font-size: 13px;"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 style="-fx-padding: 10; -fx-tab-min-height: 38px; -fx-tab-min-width: 100px;">

            <Tab text="Inicio">
                <VBox spacing="20" style="-fx-padding: 28;">
                    <HBox spacing="20">
                        <VBox alignment="CENTER" spacing="18" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                             -fx-effect: dropshadow(gaussian, rgba(63,81,181,0.14), 16, 0, 0, 5);
                             -fx-padding: 36 32;">
                            <Label fx:id="lblEstadoRRHH" text="Cargando estado..."
                                   style="-fx-font-size: 15px; -fx-text-fill: #607d8b;"/>
                            <MFXButton fx:id="btnFicharRRHH"
                                       text="Entrada"
                                       onAction="#onFicharRRHH"
                                       prefWidth="240" prefHeight="56"
                                       style="-fx-background-color: #2e7d32;
                                      -fx-text-fill: white;
                                      -fx-font-size: 17px; -fx-font-weight: bold;
                                      -fx-background-radius: 12; -fx-cursor: hand;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="Empleados">
                <HBox spacing="16" style="-fx-padding: 16;">

                    <VBox spacing="12" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <MFXTextField fx:id="txtBuscar"
                                          floatingText="Buscar por nombre, DNI o usuario..."
                                          prefWidth="340" prefHeight="44"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <MFXButton fx:id="btnNuevo"
                                       text="+ Nuevo empleado" onAction="#onNuevo"
                                       style="-fx-background-color: #1b5e20; -fx-text-fill: white;
                                              -fx-background-radius: 8; -fx-cursor: hand;
                                              -fx-font-weight: bold; -fx-padding: 10 16;"/>
                        </HBox>
                        <TableView fx:id="tablaEmpleados" VBox.vgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity">
                            <columns>
                                <TableColumn fx:id="colCod" text="Cód." prefWidth="60"/>
                                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200"/>
                                <TableColumn fx:id="colDni" text="DNI" prefWidth="100"/>
                                <TableColumn fx:id="colRol" text="Rol" prefWidth="120"/>
                                <TableColumn fx:id="colDep" text="Depto." prefWidth="130"/>
                                <TableColumn fx:id="colEstado" text="Estado" prefWidth="80"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox spacing="9" prefWidth="295" minWidth="265"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-padding: 22 18;
                                 -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.14), 14, 0, 0, 4);">

                        <Label text="Ficha de empleado"
                               style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1b5e20;"/>
                        <Separator/>

                        <MFXTextField fx:id="txtFormCod" floatingText="Código *" maxWidth="Infinity"/>
                        <MFXTextField fx:id="txtFormNombre" floatingText="Nombre *" maxWidth="Infinity"/>
                        <MFXTextField fx:id="txtFormApellido1" floatingText="Apellido 1 *" maxWidth="Infinity"/>
                        <MFXTextField fx:id="txtFormApellido2" floatingText="Apellido 2" maxWidth="Infinity"/>
                        <MFXTextField fx:id="txtFormDni" floatingText="DNI *" maxWidth="Infinity"/>
                        <MFXTextField fx:id="txtFormEmail" floatingText="Email" maxWidth="Infinity"/>
                        <MFXTextField fx:id="txtFormTelefono" floatingText="Teléfono" maxWidth="Infinity"/>
                        <MFXTextField fx:id="txtFormUsername" floatingText="Username *" maxWidth="Infinity"/>
                        <MFXPasswordField fx:id="txtFormContrasena" floatingText="Contraseña *" maxWidth="Infinity"/>

                        <Label text="Rol" style="-fx-font-size: 12px; -fx-text-fill: #78909c;"/>
                        <MFXComboBox fx:id="cmbFormRol" maxWidth="Infinity" prefHeight="40"/>

                        <Label fx:id="lblFormMensaje" text="" wrapText="true"
                               style="-fx-font-size: 12px;" visible="false"/>

                        <Separator/>

                        <HBox spacing="8">
                            <MFXButton fx:id="btnGuardar" text="Guardar"
                                       onAction="#onGuardar"
                                       HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                       style="-fx-background-color: #1b5e20; -fx-text-fill: white;
                                              -fx-cursor: hand; -fx-background-radius: 8;
                                              -fx-font-weight: bold; -fx-padding: 10;"/>
                            <MFXButton fx:id="btnBaja" text="Dar de baja"
                                       onAction="#onDarDeBaja"
                                       HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                       style="-fx-background-color: #b71c1c; -fx-text-fill: white;
                                              -fx-cursor: hand; -fx-background-radius: 8;
                                              -fx-padding: 10;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </Tab>

            <Tab text="Informes">
                <BorderPane>
                    <center>
                        <VBox spacing="24" style="-fx-padding: 36;" maxWidth="660" alignment="CENTER">
                            <Label text="Generar informe de asistencia"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1b5e20;"/>

                            <VBox spacing="18"
                                  style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-padding: 30;
                                 -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.14), 14, 0, 0, 4);">

                                <Label text="Empleado (vacío = todos):"
                                       style="-fx-font-weight: bold; -fx-text-fill: #37474f;"/>
                                <MFXComboBox fx:id="cmbEmpleadoInforme"
                                             maxWidth="Infinity" prefHeight="44"
                                             promptText="Todos los empleados"/>

                                <HBox spacing="20">
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="Desde:" style="-fx-font-weight: bold; -fx-text-fill: #37474f;"/>
                                        <MFXDatePicker fx:id="dpDesde" maxWidth="Infinity"/>
                                    </VBox>
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="Hasta:" style="-fx-font-weight: bold; -fx-text-fill: #37474f;"/>
                                        <MFXDatePicker fx:id="dpHasta" maxWidth="Infinity"/>
                                    </VBox>
                                </HBox>

                                <Separator/>

                                <HBox spacing="14">
                                    <MFXButton fx:id="btnGenerarPdf"
                                               text="Exportar PDF" onAction="#onGenerarPdf"
                                               HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="48"
                                               style="-fx-background-color: #b71c1c; -fx-text-fill: white;
                                              -fx-font-size: 14px; -fx-font-weight: bold;
                                              -fx-background-radius: 10; -fx-cursor: hand;"/>
                                    <MFXButton fx:id="btnGenerarExcel"
                                               text="Exportar Excel" onAction="#onGenerarExcel"
                                               HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="48"
                                               style="-fx-background-color: #1b5e20; -fx-text-fill: white;
                                              -fx-font-size: 14px; -fx-font-weight: bold;
                                              -fx-background-radius: 10; -fx-cursor: hand;"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </center>
                </BorderPane>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
