<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane
        xmlns:fx="http://javafx.com/fxml/1"
        xmlns="http://javafx.com/javafx/21"
        fx:controller="dev.danipraivet.controlador.ControladorAdmin"
        style="-fx-background-color: #EDE7F6;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #4a0072;
                     -fx-padding: 14 28;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10, 0, 0, 4);">
            <Label text="Clockio · Administrador"
                   style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblNombreAdmin"
                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
            <MFXButton text="Cerrar sesión" onAction="#onLogout"
                       style="-fx-background-color: rgba(255,255,255,0.18);
                              -fx-text-fill: white; -fx-background-radius: 8;
                              -fx-cursor: hand; -fx-font-size: 13px;"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 style="-fx-padding: 10; -fx-tab-min-height: 38px; -fx-tab-min-width: 110px;">

            <Tab text="Dashboard">
                <VBox spacing="24" style="-fx-padding: 32;">
                    <HBox spacing="20">
                        <VBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                                     -fx-effect: dropshadow(gaussian, rgba(21,101,192,0.16), 16, 0, 0, 5);
                                     -fx-padding: 30 24;
                                     -fx-border-color: transparent transparent transparent #1565C0;
                                     -fx-border-width: 0 0 0 5; -fx-border-radius: 0 16 16 0;">
                            <Label fx:id="lblTotalEmpleados" text="0"
                                   style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
                            <Label text="Empleados activos"
                                   style="-fx-text-fill: #90a4ae; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                                     -fx-effect: dropshadow(gaussian, rgba(27,94,32,0.16), 16, 0, 0, 5);
                                     -fx-padding: 30 24;
                                     -fx-border-color: transparent transparent transparent #2e7d32;
                                     -fx-border-width: 0 0 0 5; -fx-border-radius: 0 16 16 0;">
                            <Label fx:id="lblFichadosHoy" text="0"
                                   style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
                            <Label text="Fichados hoy"
                                   style="-fx-text-fill: #90a4ae; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                                     -fx-effect: dropshadow(gaussian, rgba(74,0,114,0.16), 16, 0, 0, 5);
                                     -fx-padding: 30 24;
                                     -fx-border-color: transparent transparent transparent #4a0072;
                                     -fx-border-width: 0 0 0 5; -fx-border-radius: 0 16 16 0;">
                            <Label fx:id="lblEstadoAdmin" text=""
                                   style="-fx-font-size: 13px; -fx-text-fill: #90a4ae;"/>
                            <MFXButton fx:id="btnFicharAdmin"
                                       text="Entrada" onAction="#onFicharAdmin"
                                       prefWidth="200" prefHeight="50"
                                       style="-fx-background-color: #2e7d32; -fx-text-fill: white;
                                              -fx-font-size: 15px; -fx-font-weight: bold;
                                              -fx-background-radius: 12; -fx-cursor: hand;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="Fichajes">
                <HBox spacing="16" style="-fx-padding: 16;">
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 4 0;">
                            <Label text="Empleado:" style="-fx-text-fill: #37474f;"/>
                            <MFXComboBox fx:id="cmbFiltroEmpleado"
                                         prefWidth="190" prefHeight="40" promptText="Todos"/>
                            <Label text="Desde:" style="-fx-text-fill: #37474f;"/>
                            <MFXDatePicker fx:id="dpFichajeDesde" prefWidth="150"/>
                            <Label text="Hasta:" style="-fx-text-fill: #37474f;"/>
                            <MFXDatePicker fx:id="dpFichajeHasta" prefWidth="150"/>
                            <MFXButton fx:id="btnBuscarFichajes"
                                       text="Buscar" onAction="#onBuscarFichajes"
                                       style="-fx-background-color: #4a0072; -fx-text-fill: white;
                                              -fx-cursor: hand; -fx-background-radius: 8;
                                              -fx-font-weight: bold; -fx-padding: 10 16;"/>
                        </HBox>
                        <TableView fx:id="tablaFichajes" VBox.vgrow="ALWAYS" prefHeight="440" maxWidth="Infinity">
                            <columns>
                                <TableColumn fx:id="colFicFecha" text="Fecha" prefWidth="100"/>
                                <TableColumn fx:id="colFicEmpleado" text="Empleado" prefWidth="120"/>
                                <TableColumn fx:id="colFicEntrada" text="Entrada" prefWidth="80"/>
                                <TableColumn fx:id="colFicSalida" text="Salida" prefWidth="80"/>
                                <TableColumn fx:id="colFicHoras" text="Horas" prefWidth="80"/>
                                <TableColumn fx:id="colFicEstado" text="Estado" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox spacing="10" prefWidth="265" minWidth="245"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-padding: 22 16;
                                 -fx-effect: dropshadow(gaussian, rgba(74,0,114,0.14), 14, 0, 0, 4);">

                        <Label text="Editar fichaje"
                               style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #4a0072;"/>
                        <Separator/>

                        <MFXTextField fx:id="txtEditEntrada" floatingText="Hora entrada (HH:mm)" maxWidth="Infinity"/>
                        <MFXTextField fx:id="txtEditSalida" floatingText="Hora salida (HH:mm)" maxWidth="Infinity"/>

                        <MFXCheckbox fx:id="chkEditFestivo" text="Día festivo"/>
                        <MFXCheckbox fx:id="chkEditJustificado" text="Justificado"/>

                        <Label text="Observaciones:" style="-fx-font-size: 12px; -fx-text-fill: #78909c;"/>
                        <TextArea fx:id="txtEditObservaciones"
                                  prefHeight="80" wrapText="true"
                                  promptText="Notas opcionales..."
                                  style="-fx-background-radius: 8;
                                         -fx-border-radius: 8;
                                         -fx-border-color: #ce93d8;"/>

                        <Separator/>

                        <MFXButton fx:id="btnGuardarFichaje"
                                   text="Guardar cambios" onAction="#onGuardarFichaje"
                                   maxWidth="Infinity"
                                   style="-fx-background-color: #4a0072; -fx-text-fill: white;
                                          -fx-cursor: hand; -fx-background-radius: 8;
                                          -fx-font-weight: bold; -fx-padding: 10;"/>
                        <MFXButton fx:id="btnEliminarFichaje"
                                   text="Eliminar fichaje" onAction="#onEliminarFichaje"
                                   maxWidth="Infinity"
                                   style="-fx-background-color: #b71c1c; -fx-text-fill: white;
                                          -fx-cursor: hand; -fx-background-radius: 8;
                                          -fx-padding: 10;"/>
                    </VBox>
                </HBox>
            </Tab>

            <Tab text="Empleados">
                <VBox spacing="12" style="-fx-padding: 16;">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <MFXTextField fx:id="txtBuscarAdmin"
                                      floatingText="Buscar por nombre o DNI..."
                                      prefWidth="320" prefHeight="44"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <MFXButton fx:id="btnDesbloquear"
                                   text="Desbloquear cuenta" onAction="#onDesbloquear"
                                   style="-fx-background-color: #e65100; -fx-text-fill: white;
                                          -fx-cursor: hand; -fx-background-radius: 8;
                                          -fx-font-weight: bold; -fx-padding: 10 16;"/>
                        <MFXButton fx:id="btnEliminarEmpleado"
                                   text="Eliminar definitivamente" onAction="#onEliminarEmpleado"
                                   style="-fx-background-color: #b71c1c; -fx-text-fill: white;
                                          -fx-cursor: hand; -fx-background-radius: 8;
                                          -fx-padding: 10 16;"/>
                    </HBox>
                    <TableView fx:id="tablaEmpleadosAdmin" VBox.vgrow="ALWAYS" prefHeight="490" maxWidth="Infinity">
                        <columns>
                            <TableColumn fx:id="colEmpNombre" text="Nombre" prefWidth="230"/>
                            <TableColumn fx:id="colEmpDni" text="DNI" prefWidth="105"/>
                            <TableColumn fx:id="colEmpRol" text="Rol" prefWidth="140"/>
                            <TableColumn fx:id="colEmpEstado" text="Estado" prefWidth="95"/>
                            <TableColumn fx:id="colEmpUltimoAcceso" text="Último acceso" prefWidth="140"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
